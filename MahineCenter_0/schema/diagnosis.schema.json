{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nkust.edu.tw/mislab/cnc/machinecenter/schema/diagnosis.schema.json",
  "title": "Diagnosis",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "diagnosis_id",
    "window_id",
    "state_label",
    "confidence",
    "model_version"
  ],
  "properties": {
    "diagnosis_id": {
      "type": "string"
    },
    "window_id": {
      "type": "string"
    },
    "machine_id": {
      "type": "string"
    },
    "holder_id": {
      "type": "string"
    },
    "state_label": {
      "type": "string",
      "enum": [
        "stable",
        "transition",
        "chatter",
        "severe_wear",
        "unknown"
      ]
    },
    "process_state_uri": {
      "type": "string"
    },
    "tool_condition_uri": {
      "type": "string"
    },
    "chatter_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "model_version": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "previous_diagnosis_id": {
      "type": "string"
    },
    "next_diagnosis_id": {
      "type": "string"
    },
    "ontology_mapping": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "class_uri": {
          "type": "string",
          "const": "sth:Diagnosis"
        },
        "individual_uri": {
          "type": "string"
        },
        "json_field_uri": {
          "type": "string"
        },
        "mqtt_topic_uri": {
          "type": "string"
        },
        "opcua_node_uri": {
          "type": "string"
        }
      }
    }
  }
}
