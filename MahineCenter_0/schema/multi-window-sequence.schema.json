{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nkust.edu.tw/mislab/cnc/machinecenter/schema/multi-window-sequence.schema.json",
  "title": "Multi-Window Sequence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "sequence_id",
    "machine_id",
    "holder_id",
    "windows"
  ],
  "properties": {
    "sequence_id": {
      "type": "string"
    },
    "machine_id": {
      "type": "string"
    },
    "holder_id": {
      "type": "string"
    },
    "nc_file_id": {
      "type": "string"
    },
    "block_id": {
      "type": "string"
    },
    "windows": {
      "type": "array",
      "items": {
        "$ref": "multi-sensor-window.schema.json"
      },
      "minItems": 1
    },
    "sequence_features": {
      "type": "object",
      "additionalProperties": {
        "type": "number"
      }
    }
  }
}
