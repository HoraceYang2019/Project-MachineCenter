{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nkust.edu.tw/mislab/cnc/machinecenter/schema/nc-block.schema.json",
  "title": "NC Block",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "block_id",
    "sequence_no",
    "code",
    "nc_file_id",
    "process_parameters"
  ],
  "properties": {
    "block_id": {
      "type": "string"
    },
    "sequence_no": {
      "type": "integer",
      "minimum": 0
    },
    "code": {
      "type": "string"
    },
    "nc_file_id": {
      "type": "string"
    },
    "tool_path_segment_id": {
      "type": "string"
    },
    "start_time": {
      "type": "string",
      "format": "date-time"
    },
    "end_time": {
      "type": "string",
      "format": "date-time"
    },
    "process_parameters": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "spindle_speed_rpm": {
          "type": "number"
        },
        "feed_rate_mm_min": {
          "type": "number"
        },
        "cutting_speed_mm_min": {
          "type": "number"
        },
        "ap_mm": {
          "type": "number"
        },
        "ae_mm": {
          "type": "number"
        }
      },
      "required": [
        "spindle_speed_rpm",
        "feed_rate_mm_min",
        "ap_mm",
        "ae_mm"
      ]
    },
    "ontology_mapping": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "class_uri": {
          "type": "string",
          "const": "sth:NCBlock"
        },
        "individual_uri": {
          "type": "string"
        },
        "json_field_uri": {
          "type": "string"
        },
        "mqtt_topic_uri": {
          "type": "string"
        },
        "opcua_node_uri": {
          "type": "string"
        }
      }
    }
  }
}
