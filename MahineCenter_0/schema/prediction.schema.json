{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nkust.edu.tw/mislab/cnc/machinecenter/schema/prediction.schema.json",
  "title": "Prediction",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "prediction_id",
    "window_id",
    "target",
    "value",
    "unit",
    "confidence",
    "model_version"
  ],
  "properties": {
    "prediction_id": {
      "type": "string"
    },
    "window_id": {
      "type": "string"
    },
    "machine_id": {
      "type": "string"
    },
    "holder_id": {
      "type": "string"
    },
    "target": {
      "type": "string",
      "enum": [
        "tool_wear_vb",
        "surface_roughness_ra",
        "torque",
        "chatter_score",
        "quality"
      ]
    },
    "value": {
      "type": "number"
    },
    "unit": {
      "type": "string"
    },
    "horizon": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "steps_ahead": {
          "type": "integer",
          "minimum": 1
        },
        "seconds_ahead": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "model_version": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "ontology_mapping": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "class_uri": {
          "type": "string",
          "const": "mis:Prediction"
        },
        "individual_uri": {
          "type": "string"
        },
        "json_field_uri": {
          "type": "string"
        },
        "mqtt_topic_uri": {
          "type": "string"
        },
        "opcua_node_uri": {
          "type": "string"
        }
      }
    }
  }
}
