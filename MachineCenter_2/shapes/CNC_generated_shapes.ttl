shape:BatchKnowledgeShape a sh:NodeShape ;
    rdfs:comment "Auto-generated SHACL shape for http://nkust.edu.tw/mislab#BatchKnowledge" ;
    sh:property [ rdfs:comment "Generated from: manual-required-profile" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path mis:forState ],
        [ rdfs:comment "Generated from: ontology-domain-range" ;
            sh:datatype xsd:float ;
            sh:path mis:hasTolerance ],
        [ rdfs:comment "Generated from: manual-required-profile, ontology-domain-range" ;
            sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path mis:hasKnowledgeCategory ],
        [ rdfs:comment "Generated from: ontology-domain-range" ;
            sh:datatype xsd:double ;
            sh:path mis:maxMeasuredRa ],
        [ rdfs:comment "Generated from: ontology-domain-range" ;
            sh:datatype xsd:double ;
            sh:path mis:minTorqueRatio ],
        [ rdfs:comment "Generated from: ontology-domain-range" ;
            sh:class mis:LoadState ;
            sh:path mis:forProcessState ],
        [ rdfs:comment "Generated from: ontology-domain-range" ;
            sh:class mis:Batch ;
            sh:path mis:forBatch ],
        [ rdfs:comment "Generated from: ontology-domain-range" ;
            sh:datatype xsd:double ;
            sh:path mis:minMeasuredRa ],
        [ rdfs:comment "Generated from: ontology-domain-range" ;
            sh:datatype xsd:double ;
            sh:path mis:maxTorqueRatio ],
        [ rdfs:comment "Generated from: ontology-domain-range" ;
            sh:datatype xsd:double ;
            sh:path mis:confidence ],
        [ rdfs:comment "Generated from: ontology-domain-range" ;
            sh:datatype xsd:string ;
            sh:path mis:hasDescription ],
        [ rdfs:comment "Generated from: ontology-domain-range" ;
            sh:datatype xsd:double ;
            sh:path mis:hasMeasuredRa ],
        [ rdfs:comment "Generated from: ontology-domain-range" ;
            sh:datatype xsd:string ;
            sh:path mis:derivedFromDataset ],
        [ rdfs:comment "Generated from: ontology-domain-range" ;
            sh:datatype xsd:double ;
            sh:path mis:maxChatterScore ],
        [ rdfs:comment "Generated from: ontology-domain-range" ;
            sh:datatype xsd:double ;
            sh:path mis:minChatterScore ] ;
    sh:targetClass mis:BatchKnowledge .

