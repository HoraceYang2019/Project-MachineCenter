PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX sth: <http://nkust.edu.tw/mislab/cnc/ontology/sth#>
PREFIX mis: <http://nkust.edu.tw/mislab#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

CONSTRUCT {
  ?window mis:hasToolCondition ?state .
}
WHERE {
  ?window rdf:type sth:MultiSensorWindow ;
          mis:belongsToBatch ?runtimeBatch ;
          mis:hasTorqueRatio ?torqueRatio .

  ?knowledge rdf:type mis:BatchKnowledge ;
             mis:forBatch ?knowledgeBatch ;
             mis:hasKnowledgeCategory ?category ;
             mis:forState ?state ;
             mis:minTorqueRatio ?minTorqueRatio ;
             mis:maxTorqueRatio ?maxTorqueRatio .

  FILTER(STR(?category) = "tool_condition")

  # Runtime batch may be mis:Batch_A, while knowledge may be mis:TMV720_Batch_A.
  BIND(REPLACE(STR(?runtimeBatch),  "^.*[#/]", "") AS ?runtimeBatchLocal)
  BIND(REPLACE(STR(?knowledgeBatch), "^.*[#/]", "") AS ?knowledgeBatchLocalRaw)
  BIND(REPLACE(?knowledgeBatchLocalRaw, "^TMV720_", "") AS ?knowledgeBatchLocal)
  FILTER(?runtimeBatchLocal = ?knowledgeBatchLocal || ?runtimeBatchLocal = ?knowledgeBatchLocalRaw)

  FILTER(xsd:double(?torqueRatio) >= xsd:double(?minTorqueRatio))
  FILTER(xsd:double(?torqueRatio) <  xsd:double(?maxTorqueRatio))
}
