    mis:hasCondition mis:STH_Comm_Fail ;
    mis:hasKnowledgeCategory "communication_quality"^^xsd:string ;
    mis:hasKnowledgeId "STH_Comm_Fail"^^xsd:string ;
    mis:hasProfile mis:STH_profile_v1 ;
    mis:hasProfileId "STH_profile_v1"^^xsd:string ;
    mis:hasRuleType "threshold"^^xsd:string ;
    mis:hasStateClass mis:CommunicationState ;
    mis:inferredProperty mis:hasCommunicationState ;
    mis:maxExclusive true ;
    mis:maxValue 4e-01 ;
    mis:minInclusive true ;
    mis:minValue 0e+00 ;
    mis:observedProperty mis:hasCommScore ;
    mis:priority 10 ;
    rdfs:comment "Communication score indicates fail."^^xsd:string .

